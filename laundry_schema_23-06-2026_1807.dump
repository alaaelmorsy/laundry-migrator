INSERT INTO `laundry_info` VALUES (2,'مغاسل القطن الأبيض','logo.png',NULL,NULL,NULL,'السادة مالكي مغاسل ألقطن الابيض','0558143839','Qw.303@hotmail.com','جازان شارع المطار','Whitecotton','5LI6E9D9-XcswD51Op5Y',0,10,5,'W-cotton',0,1,0,0,0,1,'المغسله غير مسؤولة عن الملابس بعد مرور اسبوعين عليها ولا يتم تسليم الملابس الا بالفاتورة **   المغسلة غير مسؤلة عن الاغراض الثمينة داخل الملابس وعليه نرجو التاكد من عدم وجود اغراض بداخلها *** وتلتزم المغسلة بتعويض اي قطعة تالفة بسبب الغسيل بخمسة اضعاف من قيمة غسيل القطعة\r\nلسنا الوحيدون ولكننا الافضل\r\n ',1,180,90,400,500,0,2,6,'',NULL,60,0,15,22,'2023-02-22','2023-02-23',1,'300010173700003',0,NULL,0,0,30,1,'sunny',0,0,0,1,1,'ar',21,'laundrysystem30@gmail.com','Aa12345678@','2027-05-11',NULL,'0026_B768_4C38_6335.',6,0,3,0,0,1,0,1,0,1,1,1,1,1,'2026-05-11 01:20:36',0,0,0,0,1,'#0.00',0,100,0,0,0,0,-1,NULL,'',0,'16px','16px','','',NULL,NULL,'',1,1,1,NULL,0,1,0,NULL,'',NULL,NULL,5,NULL,NULL,1,4444,5214,'3658',55555,'1010209987','Preferred Savings Establishment','Riyadh',0,NULL,NULL,0,0,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,0,0,NULL,NULL,NULL,1,1,1,0,'','',0,0,NULL,1,0);
