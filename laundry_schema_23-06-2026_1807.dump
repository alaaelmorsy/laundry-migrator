  `whatsapp_partial_payment_template` text CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci COMMENT 'Template for partial payment WhatsApp message',
  `whatsapp_bulk_bill_template` text CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci COMMENT 'Template for bulk bill WhatsApp message',
