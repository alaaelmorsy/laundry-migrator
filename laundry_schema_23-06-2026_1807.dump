  `whatsapp_send_partial_payment` tinyint(1) DEFAULT '1' COMMENT 'إرسال رسالة عند دفع جزئي (1=نعم, 0=لا)',
  `whatsapp_send_bulk_bill` tinyint(1) DEFAULT '1' COMMENT 'إرسال رسالة عند دفع فاتورة مجمعة (1=نعم, 0=لا)',
